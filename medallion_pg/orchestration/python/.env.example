# SQL Server ODBC connection string
# Example:
# MSSQL_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=YourSourceDb;UID=sa;PWD=YourPassword;TrustServerCertificate=yes;
MSSQL_CONN_STR=

# PostgreSQL connection string
# Example:
# PG_CONN_STR=host=localhost port=5432 dbname=casino_dw user=postgres password=postgres
PG_CONN_STR=

# Bronze sliding reread window (days)
BRONZE_LOOKBACK_DAYS=3

# SMTP email notifications (Prefect run status)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_TO_EMAILS=

# Daily visit-sessions report recipients (export_visit_sessions.py)
# SAFE list: always-on, receives the report on every run (healthy or degraded).
# TEAM list: added only when the data pipeline is healthy
#   (gold.fact_membership_day has rows for the report date).
# On a degraded run the team is silently dropped and the email subject is
# tagged [DEGRADED] for SAFE recipients only.
REPORT_TO_EMAILS_SAFE=data@tourinvestgroup.com
REPORT_TO_EMAILS_TEAM=artem.vorotilov@cibatumi.com,nana.khachirova@cibatumi.com,mirian.tavdgiridze@cibatumi.com,tamar.vashadze@cibatumi.com,natela.luashvili@cibatumi.com

# Override From: address for the daily report (optional).
# If unset, falls back to SMTP_FROM_EMAIL.
# IMPORTANT: many SMTP relays reject cross-domain From: addresses (anti-spoofing).
# If you set this to an address on a different domain than your SMTP-authenticated
# user, the relay may reject the send. The fix is to also configure REPORT_SMTP_*
# below to use a mail server authorized for that From: address.
REPORT_FROM_EMAIL=data@tourinvestgroup.com

# Reply-To: address for the daily report (optional).
# Recipients see REPORT_FROM_EMAIL (or SMTP_FROM_EMAIL) as sender but replies route here.
# Skipped automatically when it equals From: (avoids redundant header).
REPORT_REPLY_TO_EMAIL=data@tourinvestgroup.com

# Separate SMTP profile for the daily report (optional).
# Use this when the report needs to send From: an address NOT authorized on the
# global SMTP relay (e.g., data@tourinvestgroup.com when global is bellevuebatumi.com).
# Each REPORT_SMTP_* falls back to its global SMTP_* counterpart if unset, so you
# can leave any of them blank to inherit. The pipeline-status email is unaffected.
# REPORT_SMTP_HOST=smtp.office365.com
# REPORT_SMTP_PORT=587
# REPORT_SMTP_USERNAME=data@tourinvestgroup.com
# REPORT_SMTP_PASSWORD=
# REPORT_SMTP_USE_TLS=true
# REPORT_SMTP_USE_SSL=false