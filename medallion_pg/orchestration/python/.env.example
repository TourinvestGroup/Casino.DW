# SQL Server ODBC connection string
# Example:
# MSSQL_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=YourSourceDb;UID=sa;PWD=YourPassword;TrustServerCertificate=yes;
MSSQL_CONN_STR=

# PostgreSQL connection string
# Example:
# PG_CONN_STR=host=localhost port=5432 dbname=casino_dw user=postgres password=postgres
PG_CONN_STR=

# Bronze sliding reread window (days)
BRONZE_LOOKBACK_DAYS=3

# SMTP email notifications (Prefect run status)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_TO_EMAILS=

# Daily visit-sessions report recipients (export_visit_sessions.py)
# SAFE list: always-on, receives the report on every run (healthy or degraded).
# TEAM list: added only when the data pipeline is healthy
#   (gold.fact_membership_day has rows for the report date).
# On a degraded run the team is silently dropped and the email subject is
# tagged [DEGRADED] for SAFE recipients only.
REPORT_TO_EMAILS_SAFE=data@tourinvestgroup.com
REPORT_TO_EMAILS_TEAM=artem.vorotilov@cibatumi.com,nana.khachirova@cibatumi.com,mirian.tavdgiridze@cibatumi.com,tamar.vashadze@cibatumi.com,natela.luashvili@cibatumi.com

# Optional: override From: address for the daily report only.
# If unset, falls back to SMTP_FROM_EMAIL. Useful when the report should
# appear branded (e.g. From: data@tourinvestgroup.com) while pipeline-status
# emails keep their service-account sender.
# REPORT_FROM_EMAIL=data@tourinvestgroup.com